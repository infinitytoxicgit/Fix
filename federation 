from pyrogram.errors import FloodWait
from pyrogram.types import Message, CallbackQuery, InlineKeyboardButton, InlineKeyboardMarkup

from Oneforall import app
from Oneforall.misc import SUDOERS
from Oneforall.utils.database import (
    add_banned_user,
    get_served_chats,
    add_superban_team_member,
    remove_superban_team_member,
    get_superban_team,
    is_superban_team_member,
    add_superban_request,
    get_superban_request,
    update_superban_request_status,
    get_federations,
    add_fed_ban,
)

from Oneforall.utils.decorators.language import language
from Oneforall.utils.extraction import extract_user
from config import BANNED_USERS, superban_storage_id, OWNER_ID

LOG_GIF = "https://files.catbox.moe/2zsh0m.gif"


# ─────────────────────────────
# TEAM MANAGEMENT
# ─────────────────────────────

@app.on_message(
    filters.command(["steamadd"], prefixes=["/", "!", "."])
    & filters.user(OWNER_ID if isinstance(OWNER_ID, list) else [OWNER_ID])
)
@language
async def add_steam_member(client, message: Message, _):
    if not message.reply_to_message and len(message.command) < 2:
        return await message.reply_text(_["steam_1"])

    user = await extract_user(message)

    if await is_superban_team_member(user.id):
        return await message.reply_text(_["steam_2"].format(user.mention))

    await add_superban_team_member(user.id)
    await message.reply_text(_["steam_3"].format(user.mention))


@app.on_message(filters.command(["steamrem"], prefixes=["/", "!", "."]) & filters.user(list(SUDOERS)))
@language
async def remove_steam_member(client, message: Message, _):
    if not message.reply_to_message and len(message.command) < 2:
        return await message.reply_text(_["steam_4"])

    user = await extract_user(message)

    if not await is_superban_team_member(user.id):
        return await message.reply_text(_["steam_5"].format(user.mention))

    await remove_superban_team_member(user.id)
    await message.reply_text(_["steam_6"].format(user.mention))


@app.on_message(filters.command(["steamlist"], prefixes=["/", "!", "."]) & filters.user(list(SUDOERS)))
@language
async def list_steam_members(client, message: Message, _):
    members = await get_superban_team()

    if not members:
        return await message.reply_text(_["steam_7"])

    msg = _["steam_8"]
    for i, uid in enumerate(members, start=1):
        try:
            user = await app.get_users(uid)
            msg += f"\n{i}. {user.mention} (`{uid}`)"
        except:
            msg += f"\n{i}. `{uid}`"

    await message.reply_text(msg)


# ─────────────────────────────
# SUPERBAN REQUEST
# ─────────────────────────────

@app.on_message(filters.command(["superban"], prefixes=["/", "!", "."]))
@language
async def superban_request(client, message: Message, _):
    if not superban_storage_id:
        return await message.reply_text(_["sb_1"])

    if not message.reply_to_message and len(message.command) < 2:
        return await message.reply_text(_["sb_2"])

    user = await extract_user(message)
    reason = " ".join(message.command[2:]) or "no reason provided"

    request_id = uuid4().hex[:12]

    request_data = {
        "request_id": request_id,
        "user_id": user.id,
        "user_mention": user.mention,
        "username": user.username or "n/a",
        "first_name": user.first_name or "n/a",
        "requested_by": message.from_user.mention,
        "requester_id": message.from_user.id,
        "chat_id": message.chat.id,
        "chat_title": message.chat.title,
        "message_id": message.message_id,
        "reason": reason,
        "timestamp": datetime.now().isoformat(),
        "status": "pending",
    }

    await add_superban_request(request_id, request_data)

    buttons = InlineKeyboardMarkup([
        [
            InlineKeyboardButton("✅ ACCEPT", callback_data=f"sb_accept_{request_id}"),
            InlineKeyboardButton("❌ DECLINE", callback_data=f"sb_decline_{request_id}")
        ]
    ])

    log_msg = (
        f"🔔 **SUPERBAN REQUEST**\n\n"
        f"👤 User: {user.mention}\n"
        f"🆔 ID: `{user.id}`\n"
        f"📌 Reason: {reason}\n"
        f"👨‍💼 By: {message.from_user.mention}\n"
        f"💬 Group: {message.chat.title}\n"
        f"⏰ Time: {datetime.now().strftime('%d-%m-%Y %H:%M:%S')}"
    )

    try:
        await app.send_message(superban_storage_id, log_msg, reply_markup=buttons)
    except Exception as e:
        await message.reply_text(f"Failed: {e}")

    await message.reply_text(_["sb_3"].format(user.mention))


# ─────────────────────────────
# ACCEPT CALLBACK
# ─────────────────────────────

@app.on_callback_query(filters.regex(r"^sb_accept_"))
async def accept_superban(client, callback: CallbackQuery):

    is_member = await is_superban_team_member(callback.from_user.id)
    if not is_member:
        return await callback.answer("Not in team!", show_alert=True)

    request_id = callback.data.replace("sb_accept_", "")
    request = await get_superban_request(request_id)

    if not request:
        return await callback.answer("Not found!", show_alert=True)

    user_id = request["user_id"]

    await update_superban_request_status(request_id, "accepted")

    if isinstance(BANNED_USERS, set):
        BANNED_USERS.add(user_id)
    else:
        BANNED_USERS.append(user_id)

    chats = await get_served_chats()
    chat_ids = [int(c["chat_id"]) for c in chats]

    done = 0
    msg = await callback.message.reply_text("Processing global ban...")

    for chat_id in chat_ids:
        try:
            await app.ban_chat_member(chat_id, user_id)
            done += 1
        except FloodWait as e:
            await asyncio.sleep(e.value)
        except:
            pass

    await add_banned_user(user_id)

    # federation
    federations = await get_federations()
    fed_total = 0

    for fed in federations:
        fed_chats = fed.get("chats", [])
        fed_total += len(fed_chats)

        await add_fed_ban(fed["fed_id"], user_id, request["reason"])

        for chat_id in fed_chats:
            try:
                await app.ban_chat_member(chat_id, user_id)
            except:
                pass

    await callback.edit_message_text(
        callback.message.text + f"\n\nAccepted by {callback.from_user.mention}"
    )

    await msg.delete()

    await callback.answer(
        f"Banned in {done + fed_total} chats",
        show_alert=True
    )


# ─────────────────────────────
# DECLINE CALLBACK
# ─────────────────────────────

@app.on_callback_query(filters.regex(r"^sb_decline_"))
async def decline_superban(client, callback: CallbackQuery):

    owners = OWNER_ID if isinstance(OWNER_ID, list) else [OWNER_ID]

    is_member = (
        callback.from_user.id in owners
        or await is_superban_team_member(callback.from_user.id)
    )

    if not is_member:
        return await callback.answer("Not allowed!", show_alert=True)

    request_id = callback.data.replace("sb_decline_", "")
    request = await get_superban_request(request_id)

    if not request:
        return await callback.answer("Not found!", show_alert=True)

    await update_superban_request_status(request_id, "declined")

    await callback.edit_message_text(
        callback.message.text + f"\n\nDeclined by {callback.from_user.mention}"
    )

    await callback.answer("Declined", show_alert=True)